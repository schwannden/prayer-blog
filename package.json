{
  "name": "tailwind-nextjs-prayer-book",
  "version": "1.1.10",
  "private": true,
  "scripts": {
    "start": "next dev --webpack",
    "dev": "cross-env INIT_CWD=$PWD next dev --webpack",
    "build": "cross-env INIT_CWD=$PWD next build --webpack && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "eslint --fix app components layouts scripts",
    "prepare": "husky"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@headlessui/react": "2.2.10",
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.10",
    "@tailwindcss/typography": "^0.5.20",
    "braces": "^3.0.3",
    "contentlayer2": "^0.5.8",
    "cross-spawn": "^7.0.6",
    "esbuild": "0.28.1",
    "github-slugger": "^2.0.0",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.2",
    "micromatch": "^4.0.8",
    "next": "16.2.9",
    "next-contentlayer2": "^0.5.7",
    "next-themes": "^0.4.6",
    "pliny": "^0.4.1",
    "postcss": "^8.5.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.3",
    "unist-util-visit": "^5.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/braces": "^3",
    "@types/mdx": "^2.0.14",
    "@types/micromatch": "^4",
    "@types/node": "^24.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.29.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "volta": {
    "node": "24.16.0",
    "npm": "11.13.0"
  }
}
